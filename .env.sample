KEKA_EMAIL=your_email@example.com
KEKA_PASSWORD=your_password
KEKA_URL=https://changeme.keka.com
# optional: free API key from https://aistudio.google.com - reads the login captcha automatically
GEMINI_API_KEY=your_gemini_api_key
# optional: OpenAI-compatible vision solver, tried before Gemini. On GitHub
# Actions this uses GitHub Models (gpt-4o-mini) via the built-in GITHUB_TOKEN.
# VISION_BASE_URL=https://models.github.ai/inference
# VISION_MODEL=openai/gpt-4o-mini
# VISION_API_KEY=your_token
# optional: status emails after each run, via any SMTP provider.
# Example below is a PERSONAL Gmail (work Google accounts often block app passwords):
# SMTP_USER is the sending Gmail, SMTP_PASSWORD is a 16-char app password
# from https://myaccount.google.com/apppasswords (needs 2FA on). NOTIFY_EMAIL is the recipient.
NOTIFY_EMAIL=vansh@hudle.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_personal_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# 2FA OTP: Keka emails a login OTP on every fresh (no saved session) login,
# e.g. on GitHub Actions. Forward those OTP emails to a Gmail you can read over
# IMAP, and the script pulls the code automatically. Defaults to SMTP_USER/
# SMTP_PASSWORD above (same Gmail; an app password works for IMAP too), so you
# usually don't need to set these.
# IMAP_HOST=imap.gmail.com
# IMAP_USER=your_personal_gmail@gmail.com
# IMAP_PASSWORD=your_gmail_app_password
# OTP_SUBJECT=One-Time Password
# OTP_TIMEOUT=150
